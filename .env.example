# Create a fresh Binance TH API key, paste it into a local .env file, and keep this file out of chat/git.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Default provider is Binance TH. Use Binance TH API credentials with this provider.
BINANCE_PROVIDER=binance_th

# Use "live" for the real Binance TH Spot account.
# Binance TH does not use Binance global Spot Testnet endpoints.
BINANCE_ENV=live

# Binance TH API endpoints.
BINANCE_BASE_URL=https://api.binance.th
BINANCE_PUBLIC_BASE_URL=https://api.binance.th

# Optional persistent PostgreSQL storage, such as Supabase Transaction Pooler.
# Leave empty for local JSON files. Set on Render to persist config/history/logs.
DATABASE_URL=

# Memory controls for small Render instances.
ACCOUNT_TRADE_LIMIT=200
PORTFOLIO_SNAPSHOT_MIN_INTERVAL_SECONDS=600

# Safety defaults: the dashboard can read account data, but real orders are blocked.
ENABLE_LIVE_TRADING=false
ALLOW_AI_LIVE_ORDERS=false

# Guardrails for any live order request.
MAX_ORDER_USDT=30
MAX_BTC_QTY=0.0003

# AI-specific guardrails. AI_ORDER_USDT is the max USDT per AI BUY.
# AI_ORDER_BTC_QTY is the BTC amount per AI SELL.
# AI_DAILY_BUDGET_USDT is the max AI BUY spend per UTC day.
AI_ORDER_USDT=10
AI_ORDER_BTC_QTY=0.0001
AI_DAILY_BUDGET_USDT=30

# Background bot worker. It runs only while the web service process is awake.
BACKGROUND_BOT_ENABLED=true
BOT_CHECK_INTERVAL_MINUTES=15
BOT_STARTUP_DELAY_SECONDS=60

# Server settings.
APP_HOST=127.0.0.1
APP_PORT=8000
